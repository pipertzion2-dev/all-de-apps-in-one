{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm run build:vercel",
  "crons": [
    {
      "path": "/api/cron/run-scheduled?job=seo",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/run-scheduled?job=growth",
      "schedule": "0 7 * * 0"
    }
  ]
}
