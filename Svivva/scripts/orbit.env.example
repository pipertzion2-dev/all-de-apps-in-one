# Orbit marketing CLI config.
# Copy this to ".env.orbit" in the Svivva project root, then fill it in:
#     cp scripts/orbit.env.example .env.orbit
# Lets `npm run orbit:*` drive the live marketing engine without opening svivva.com.

# Your live site (no trailing slash).
SVIVVA_URL=https://svivva.com

# Shared internal secret — MUST match ORBIT_INTERNAL_SECRET in Vercel
# (Vercel -> Project -> Settings -> Environment Variables -> ORBIT_INTERNAL_SECRET).
ORBIT_INTERNAL_SECRET=

# Optional: upgrade the marketing/research model server-side once you add credits.
# Set this in Vercel too (not just here) so the deployed engine uses it.
#   e.g. gpt-5, gpt-4o, or an AI Gateway model id
# ORBIT_AI_MODEL=
