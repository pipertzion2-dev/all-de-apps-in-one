# ─── Core (required) ─────────────────────────────────────────
# Local: from repo root run `docker compose up -d postgres` (see ../docker-compose.yml), then use:
DATABASE_URL=postgresql://svivva:svivva_local_dev@127.0.0.1:5432/svivva

# Public site URL (no trailing slash) — Orbit, Seeds funnel, IndexNow, sitemap pings, and UI copy all derive from this.
# Production example: https://svivva.com
# Local Mac browser: http://127.0.0.1:5000 is fine. On another device (phone), 127.0.0.1 is THAT device — use your Mac's LAN IP instead, e.g. http://192.168.1.10:5000 (Orbit shows a copyable hint when you open localhost).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:5000

# Clutety (embedded Pyracrypt UI) — main page path and live app iframe URL.
# NEXT_PUBLIC_CLUTETY_MAIN_URL=https://svivva.com/clutety
# NEXT_PUBLIC_CLUTETY_APP_URL=https://pyracrypt.replit.app
# NEXT_PUBLIC_CLUTETY_MINI_APPS_URL=https://svivva.com/ai-tools-hub
# Legacy aliases still work: NEXT_PUBLIC_PYRACRYPT_MAIN_URL, NEXT_PUBLIC_PYRACRYPT_MINI_APPS_URL

# Dev server port (default 5000). macOS often reserves :5000 for AirPlay Receiver — if `npm run dev` fails with EADDRINUSE, set both:
# PORT=3000
# NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Server-to-server calls (optional). Defaults to NEXT_PUBLIC_SITE_URL, then VERCEL_URL.
# INTERNAL_APP_ORIGIN=http://127.0.0.1:5000

# Strong random string for session / crypto where applicable
NEXTAUTH_SECRET=

# ─── OpenID (Replit Auth today) ───────────────────────────────
# On Replit, REPL_ID is injected. Elsewhere you must migrate issuer + client (see docs).
# ISSUER_URL=https://replit.com/oidc
# OIDC_CLIENT_ID=
# REPL_ID=

# Optional: store the same keys in Postgres from /dashboard/settings/runtime-keys (admin) when host env is empty.

# ─── OpenAI (optional — not used by Orbit marketing steps) ─────
OPENAI_API_KEY=
# Replit AI Integrations proxy (optional alternative to OPENAI_API_KEY)
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Orbit free AI (recommended on Vercel — Orbit ignores OPENAI_API_KEY) ──
# Google AI Studio (free tier): create a key and paste here — same OpenAI-compatible client.
# GEMINI_API_KEY=
# Self-hosted Ollama (optional): public URL of your Ollama /v1 endpoint.
# OLLAMA_URL=http://127.0.0.1:11434

# ─── Stripe (payments + checkout + portal) ─────────────────────
# Keys: https://dashboard.stripe.com/apikeys — use the same account as before; copy Secret + Publishable into Vercel/host env (or admin → /dashboard/settings/runtime-keys).
# Webhook: https://YOUR_DOMAIN/api/stripe/webhook — if the site domain changed, add a new endpoint in Stripe (Developers → Webhooks) and paste the new signing secret as STRIPE_WEBHOOK_SECRET.
# Events: checkout.session.completed, customer.subscription.deleted
# Products: optional one-time `npm run stripe:seed` (with STRIPE_SECRET_KEY set) if Pro/Enterprise prices are missing.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Client-side Elements (optional if you only use publishable-key API route)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Site owner id(s) for Orbit, Growth, marketing APIs, Traffic, GSC (Replit OIDC `sub`, Clerk id, etc.). Comma-separated = multiple admins.
# Required on production builds: if unset in NODE_ENV=production, no account is treated as admin.
# In local dev (next dev), if unset, any signed-in user is treated as admin for convenience.
# ADMIN_USER_ID=

# ─── Background jobs / automation ───────────────────────────
# Shared secret for internal API calls (SEO scheduler, growth tasks)
ORBIT_INTERNAL_SECRET=
# Optional: user_id for internal Orbit/cron when it must differ from the first `ADMIN_USER_ID`. If unset, `ADMIN_USER_ID` (first) is used, then the latest `seed_credentials` row.
# ORBIT_INTERNAL_USER_ID=

# Vercel Cron: set in Vercel project env; Vercel sends Authorization: Bearer CRON_SECRET
CRON_SECRET=

# Dev SEO scheduler interval (hours)
# SEO_AUTO_INTERVAL_HOURS=24

# ─── Analytics (optional) ─────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GADS_ID=
# NEXT_PUBLIC_CLARITY_ID=

# ─── Google Search Console (optional) ─────────────────────────
# Verification token for <meta name="google-site-verification" ...>. Recommended
# for prod — deterministic across users. Falls back to the row scoped to
# ADMIN_USER_ID, then to any saved row, if unset.
# Get this from search.google.com/search-console → Settings → Ownership verification → HTML tag.
# GOOGLE_SITE_VERIFICATION=

# Sitemap submission to GSC uses a service-account JSON pasted at /dashboard/gsc-connect.
# (No env var — stored in the database, scoped to ADMIN_USER_ID for cron use.)

# ─── GoDaddy / marketing integrations (optional) ──────────────
# Set your apex domain + API keys in the dashboard: Marketing → Traffic Setup, or Orbit → Connections Hub.
# Domain must match the name registered at GoDaddy (e.g. mysite.com). Use NEXT_PUBLIC_SITE_URL so "Fill domain" works.
# API keys: https://developer.godaddy.com/keys

# ─── Linked funnel apps (replace Replit defaults after you deploy elsewhere) ─
# NEXT_PUBLIC_PYRACRYPT_MAIN_URL=https://main.yourdomain.com
# NEXT_PUBLIC_PYRACRYPT_MINI_APPS_URL=https://mini.yourdomain.com
